model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  address   String?
  role      Role
  isBan     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  technicianProfile TechnicianProfile?
  bookings          Booking[]          @relation("CustomerBookings")
  reviews           Review[]
  payments          Payment[]

  @@index([email])
  @@index([role])
  @@map("users")
}
