model User {
  id                String             @id @default(uuid())
  email             String             @unique
  password          String
  name              String
  role              Role
  phone             String?
  address           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  isBan             Boolean            @default(false)
  bookings          Booking[]          @relation("CustomerBookings")
  payments          Payment[]
  reviews           Review[]
  technicianProfile TechnicianProfile?

  @@index([email])
  @@index([role])
  @@map("users")
}
