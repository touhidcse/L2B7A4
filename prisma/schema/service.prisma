model Service {
  id           String            @id @default(uuid())
  title        String
  description  String
  categoryId   String
  technicianId String
  price        Float
  bookings     Booking[]
  category     Category          @relation(fields: [categoryId], references: [id])
  technician   TechnicianProfile @relation(fields: [technicianId], references: [id])

  @@index([technicianId])
  @@index([categoryId])
  @@map("services")
}
