model TechnicianProfile {
  id String @id @default(uuid())
  userId String @unique
  experience Int @default(0)
  profilePhoto String?
  bio String?
  rating Float @default(0)

  user User @relation(fields: [userId], references: [id])
  services Service[]
  bookings Booking[]
  reviews Review[]

  @@index([userId])
  @@map("technician_profiles")
}
